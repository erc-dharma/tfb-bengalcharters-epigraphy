         <div type="edition" xml:lang="san-Latn">
             <pb n="r"/><lb n="1"/><p><g ref="sym:spiral-right" type="symbol">*</g> Om̐ namo nārāyaṇāya</p>
             <lg n="1" met="śārdūlavikrīḍita">
                 <l n="a">vidyud yatra maṇi-dyutiḥ phaṇi-pater vālendur indrāyudhaṁ</l>
                 <l n="b">vā<g ref="sym:bar" type="connector">§</g><lb n="2" break="no"/>ri svargga-taraṅgiṇī sita-śiro-mālā valākāvaliḥ<g ref="sym:shortBar" type="punctuation">,</g></l>
                 <l n="c">dhyānābhyāsa-samīraṇopanihitaḥ<lb n="3"/> śreyo ’ṅkurodbhūtaye</l>
                 <l n="d">bhūyād vaḥ sa bhavārtti-tāpa-bhiduraḥ śambhoḥ kaparddāmvu-daḥ<g ref="sym:doubleBar" type="punctuation">.</g><!--Two daṇḍas are connected on their top by a horizontal bar. --></l>
             </lg>
             <lg n="2" met="śārdūlavikrīḍita">
                 <l n="a">Ā<lb n="4" break="no"/>nando <supplied reason="omitted">’</supplied>mvu-nidhau cakora-nikare du<choice><sic>ṣ</sic><corr>ḥ</corr></choice>kha-cchidātyantikī</l>
                 <l n="b">kahlāre hata-mohyatā<lb n="5"/> rati-patāv eko <supplied reason="omitted">’</supplied>ham eveti dhīḥ<g ref="sym:shortBar" type="punctuation">,</g></l>
                 <l n="c">yasyāmī Amr̥tātmanaḥ samudayanty āśu prakā<lb n="6" break="no"/>śāj jagaty</l>
                 <l n="d">attri-dhyāna-paramparā-pariṇataṁ jyotis tad āstām mude<g ref="sym:doubleBar" type="punctuation">.</g><!--Two daṇḍas are connected on their top by a horizontal bar. --></l>
             </lg>
             <lg n="3" met="vasantatilakā">
                 <l n="a">sevāvana<lb n="7" break="no"/>mra-nr̥pa-koṭi-kirīṭa-rocir</l>
                 <l n="b">-amv<choice><sic>u</sic><corr>ū</corr></choice>llasaT-pada-nakha-dyuti-val<supplied reason="omitted">l</supplied>arībhiḥ<g ref="sym:shortBar" type="punctuation">,</g></l>
                 <l n="c">tejo<lb n="8" break="no"/>-viṣa-jvara-muṣo dviṣatām abhūvan·</l>
                 <l n="d">bhūmī-bhujaḥ sphuṭam athauṣadhi-nātha-vaṁ<lb n="9" break="no"/>śe<g ref="sym:doubleBar" type="punctuation">.</g><!--Two daṇḍas are connected on their top by a horizontal bar. --></l>
             </lg>
             <lg n="4" met="śārdūlavikrīḍita">
                 <l n="a">Ā-kaumāra-vikasvarair ddiśi diśi prasyandibhir ddor-yaśaḥ</l>
                 <l n="b">-prāleyair ari-rā<lb n="10" break="no"/>ja-vaktra-nalina-mlānīḥ samunmīlayan·<supplied reason="omitted"><g ref="sym:bar" type="punctuation">,</g></supplied></l>
                 <l n="c">hemantaḥ sphuṭam e<choice><sic>y</sic><corr>v</corr></choice>a sena-janana-kṣetrau<lb n="11" break="no"/>gha-puṇyāvalī</l>
                 <l n="d">-śāli-ślāghya-vipāka-pīvara-guṇas teṣām abhūd vaṁśa-jaḥ<supplied reason="omitted"><g ref="sym:doubleBar" type="punctuation">.</g></supplied></l>
             </lg>
             <lg n="5" met="śikhariṇī">
                 <l n="a">yadīyair a<lb n="12" break="no"/>dyāpi pracita-bhuja-tejaḥ-sahacarair</l>
                 <l n="b">yaśobhiḥ śobhante paridhi-pari<lb n="13" break="no"/>ṇaddhā Iva diśaḥ<g ref="sym:shortBar" type="punctuation">,</g></l>
                 <l n="c">tataḥ kāñcī-līlā-catura-catur-ambho-dhi-laharī</l>
                 <l n="d">-parītorvvī<lb n="14" break="no"/>-bharttājani vijayasenaḥ sa vijayī<g ref="sym:doubleBar" type="punctuation">.</g><!--Two daṇḍas are connected on their top by a horizontal bar. --></l>
             </lg>
             <lg n="6" met="śārdūlavikrīḍita">
                 <l n="a">pratyūhaḥ kali-sampadām analaso vedā<lb n="15" break="no"/>yanaikādhvagaḥ</l>
                 <l n="b">saṅgrāmaḥ śrita-jaṅgamākr̥tir abhūd vallālasenas tataḥ<g ref="sym:Bar" type="punctuation">,</g></l>
                 <l n="c">yaś cetoma<lb n="16" break="no"/>yam eva śaurya-vijayī datvauṣadhaṁ taT-kṣaṇād</l>
                 <l n="d">akṣīṇā racayāñ cakāra vaśagāḥ<lb n="17"/> svasmin· pareṣāṁ śriyaḥ<g ref="sym:doubleBar" type="punctuation">.</g><!--Two daṇḍas are connected on their top by a horizontal bar. --></l>
             </lg>
             <lg n="7" met="śārdūlavikrīḍita">
                 <l n="a">saṁbhuktānya-dig-aṅganā-gaṇa-guṇābhoga-pralobhād diśā<lb n="18" break="no"/>m</l>
                 <l n="b">īśair aṁśa-samarppaṇena ghaṭitas tat-taT-prabhāva-sphuṭaiḥ<g ref="sym:smallBar" type="punctuation">,</g></l>
                 <l n="c">dor-uṣma-kṣapi<lb n="19" break="no"/>tāri-saṅga-raraso rājanya-dharmmāśrayaḥ</l>
                 <l n="d">śrīma<supplied reason="omitted">l</supplied>-lakṣmaṇasena-bhū-patir ataḥ sau<lb n="20" break="no"/>janya-sīmājani<space unit="character" quantity="1" type="vacat"/><g ref="sym:doubleBar" type="punctuation">.</g><!--Two daṇḍas are connected on their top by a horizontal bar. --></l>
             </lg>
         </div>
