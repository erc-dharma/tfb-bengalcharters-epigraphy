      <body>
         <div type="edition" xml:lang="san-Latn">
             <lb n="1"/><p><g ref="sym:spiral-right" type="symbol">*</g> Om̐ namaḥ śivāya<g ref="sym:doublBar-serifed" type="punctuation">.</g></p>
            <lg n="1" met="vasantatilakā">
                 <l n="a">vakṣoṁśukāharaṇa-sādhvasa-kr̥ṣṭa-mauli</l>
                 <l n="b">-mālya-cchaṭā-hata-ratālaya-dīpa-bhāsaḥ<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">devyās trapā-mukulitaṁ mukham indu-bhābhir</l>
                 <l n="d">vvīkṣyānanāni hasitāni jayanti śambhoḥ<g ref="sym:doubleBar-serifed">.</g></l>
             </lg>
             <lg n="2" met="śārdūlavikrīḍita">
                 <l n="a">lakṣmī-vallabha<g ref="sym:bar" type="connector">§</g><lb n="2" break="no"/>-śailajā-dayitayor advaita-līlā-gr̥haṁ</l>
                 <l n="b">pradyumneśvara-śavda-lāñchanam adhiṣṭhānaṁ namas kurmmahe<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">yatrāliṅgana-bhaṅga-kātaratayā<del rend="strikeout">ṁ</del> sthitvāntare kāntayor</l>
                 <l n="d">ddevībhyāṁ kathamapy abhinna-tanutā-śilpe ’ntarāyaḥ kr̥taḥ<g ref="sym:doubleBar-serfed" type="punctuation">.</g></l>
             </lg>
             <lg n="3" met="śārdūlavikrīḍita">
                 <l n="a">yat-siṁhāsanam īśvara<g ref="sym:bar" type="connector">§</g><lb n="3" break="no"/>sya kanaka-prāyaṁ jaṭā-maṇḍalaṁ</l>
                 <l n="b">gaṅgā-śīkara-mañjarī-parikarair yac-cāmara-prakriyā<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">śvetotphulla-phaṇāñcalaḥ śiva-śiraḥ-sandāna-dūmoragaś</l>
                 <l n="d">chattraṁ yasya jayaty asāv acaramo rājā sudhā-dīdhitiḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
             </lg>
             <lg n="4" met="sragdharā">
                 <l n="a">vaṁśe tasyāmara-strī-vi<lb n="4" break="no"/>tata-rata-kalā-sākṣiṇo dākṣiṇātya</l>
                 <l n="b">-kṣoṇīndrair vvīrasena-prabhr̥tibhir abhitaḥ kīrttimadbhir vvabhūve<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">yac-cāritrānucintā-paricaya-śucayaḥ sūkti-mādhvīka-dhārāḥ</l>
                 <l n="d">pārāśaryeṇa viśva-śravaṇa-parisara-prīṇanāya praṇītāḥ<g ref="sym:doubleBar-serifed">.</g></l>
             </lg>
             <lg n="5" met="sragdharā">
                 <l n="a">asmin· se<lb n="5" break="no"/>nānvavāye prati-subhaṭa-śatotsādana-vrahma-vādī</l>
                 <l n="b">sa vrahma-kṣattriyāṇām ajani kula-śiro-dāma sāmantasenaḥ<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">Udgīyante yadīyaḥ skhalad-udadhi-jalollola-śīteṣu setoḥ</l>
                 <l n="d">kacchānteṣv apsarobhir ddaśaratha-tanaya-sparddhayā yuddha-gāthā<lb n="6" break="no"/>ḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
             </lg>
             <lg n="6" met="śārdūlavikrīḍita">
                 <l n="a">yasmin· saṅgara-catvare paṭu-raṭat-tūryopahūta-dviṣad</l>
                 <l n="b">-vargge yena kr̥pāṇa-kāla-bhujagaḥ khelayitaḥ pāṇinā<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">dvaidhī-bhūta-vipakṣa-kuñjara-ghaṭā-viśliṣṭa-kumbha-sthalī</l>
                 <l n="d">-muktā-sthūla-varāṭikā-parikarair vvyā<lb n="7" break="no"/>ptaṁ tad adyāpy abhūt·<g ref="sym:doubleBar" type="punctuation">.</g></l>
             </lg>
             <lg n="7" met="pr̥thvī">
                 <l n="a">gr̥hād gr̥ham upāgataṁ vrajati pattanaṁ pattanād</l>
                 <l n="b">vanād vanam anudrutaṁ bhramati pādapaṁ pādāt·<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">girer ggirim adhiśritan tarati toya-dhin toya-dher</l>
                 <l n="d">yadīyam ari-sundarī-saraka-pr̥ṣṭha-lagnaṁ yaśaḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
             </lg>
             <lg n="8" met="mandākrāntā">
                 <l n="a">durvvr̥ttānām ayam ari<lb n="8" break="no"/>-kulākīrṇṇa-karṇṇāṭa-lakṣmī</l>
                 <l n="b">-luṇṭākānāṁ kadanam atanot tādr̥g-ekāṅga-vīraḥ<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">yasmād adyāpy avihata-vasā-mānsa-medhaḥ-subhikṣāṁ</l>
                 <l n="d">hr̥ṣyat·-pauras tyajati na diśaṁ dakṣiṇāṅ pre<unclear>ta</unclear>-bharttā<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
             </lg>
             <lg n="9" met="sragdharā">
                 <l n="a">Udgandhīny ājya-dhūmair mmr̥ga-śiśu-rasitākhinna<lb n="9" break="no"/>-vaikhānasa-strī</l>
                 <l n="b">-stanya-kṣīrāṇi kīra-prakara-paricita-vrahma-pārāyaṇāni<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">yenāsevyanta śeṣe vayasi bhava-bhayāskandibhir mmaskarīndraiḥ</l>
                 <l n="d">pūrṇṇotsaṅgāni gaṅgā-pulina-parisarāraṇya-puṇyāśramāṇi<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
             </lg>
             <lg n="10" met="mālinī">
                 <l n="a">Acarama-paramātma-jñāna-bhī<lb n="10" break="no"/>ṣmād amuṣmān</l>
                 <l n="b">nija-bhuja-mada-mattārāti-mārāṅka-vīraḥ<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">Abhavad anavasānodbhinna-nirṇṇikta-tat-tad</l>
                 <l n="d">-guṇa-nivaha-mahimnāṁ veśma hemantasenaḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
             </lg>
             <lg n="11" met="sragdharā">
                 <l n="a">mūrddhany arddhendu-cūḍā-maṇi-caraṇa-rajaḥ satya-vāk kaṇṭha-bhittau</l>
                 <l n="b">śāstraṁ śrotre <supplied reason="omitted">’</supplied>ri<lb n="11" break="no"/>-keśāḥ pada-bhuvi bhujayoḥ krūra-maurvvī-kiṇāṅkaḥ<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">nepathyaṁ yasya jajñe satatam iyad idaṁ ratna-puṣpāṇi hārās</l>
                 <l n="d">tāḍaṅkaṁ nūpura-srak-kanaka-valayam apy asya bhr̥tyāṅganānām·<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
             </lg>
             <lg n="12" met="śārdūlavikrīḍita">
                 <l n="a">yad-dor-valli-vilāsa-lavdha-gatibhiḥ śalyair vvidīrṇṇorasāṁ<g ref="sym:bar" type="connector">§</g><lb n="12"/></l>
                 <l n="b">vīrāṇāṁ raṇa-tīrtha-vaibhava-vaśād divyaṁ vapur vvibhratām·<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">saṁsaktāmara-kāminī-stana-taṭī-kāśmīra-pattāṅkitaṁ</l>
                 <l n="d">vakṣaḥ prāg iva mugdha-siddha-mithunaiḥ sātaṅkam ālokitam·<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
             </lg>
             <lg n="13" met="śārdūlavikrīḍita">
                 <l n="a">pratyarthi-vyaya-keli-karmmaṇi puraḥ smeraṁ mukhaṁ vibhrator</l>
                 <l n="b">e<lb n="13" break="no"/>tasyaitad aseś ca kauśalam abhūd dāne dvayor adbhutam·<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">śatroḥ ko <supplied reason="omitted">’</supplied>pi dadhe ’vasādam aparaḥ sakhyuḥ prasādaṁ vyadhād</l>
                 <l n="d">eko hāram upājahāra suhr̥dām anyaḥ prahāraṁ dviṣām·<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
             </lg>
             <lg n="14" met="śikhariṇī">
                 <l n="a">mahā-rājñī yasya sva-para-nikhilāntaḥpura-vadhū<lb n="14" break="no"/></l>
                 <l n="b">-śiro-ratna-śreṇī-kiraṇa-saraṇi-smera-caraṇā<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">nidhiḥ kānte<add place="inline">ḥ</add> sādhvī-vrata-vitata-nityojjvala-yaśā</l>
                 <l n="d">yaśodevī-nāma tri-bhuvana-mano-jñākr̥tir abhūt·<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
             </lg>
             <lg n="15" met="pr̥thvī">
                 <l n="a">tatas tri-jagad-īśvarāt samajaniṣṭa devyās tato <supplied reason="omitted">’</supplied>py</l>
                 <l n="b">arāti-vala-śātanojjva<lb n="15" break="no"/>la-kumāra-keli-kramaḥ<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">catur-jjala-dhi-mekhalā-valaya-sīma-viśvambharā</l>
                 <l n="d">-viśiṣṭa-jaya-sānvayo vijayasena-pr̥thvī-patiḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
             </lg>
             <lg n="16" met="mālinī">
                 <l n="a">gaṇayatu gaṇaśaḥ ko bhūpatīṁs tān anena</l>
                 <l n="b">prati-dina-raṇa-bhājā ye jitā vā hatā vā<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">Iha jagati viṣe<lb n="16" break="no"/>he svasya vaṁśasya pūrvvaḥ</l>
                 <l n="d">puruṣa Iti sudhāṁśau kevalaṁ rāja-śavdaḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
             </lg>
             <lg n="17" met="śārdūlavikrīḍita">
                 <l n="a">saṁkhyātīta-kapīndra-sainya-vibhunā tasyāri-jetus tulāṁ</l>
                 <l n="b">kiṁ rāmeṇa vadāma pāṇḍava-camū-nāthena pārthena vā<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">hetoḥ khaḍga-latāvataṁsita-bhujā-mātrasya yenārjjitaṁ</l>
                 <l n="d">saptā<g ref="sym:bar" type="connector">§</g><lb n="17" break="no"/>mbho-dhi-taṭī-pinaddha-vasudhā-cakraika-rājyaṁ phalam·<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
             </lg>
             <lg n="18" met="śārdūlavikrīḍita">
                 <l n="a">Ekaikena guṇena yaiḥ pariṇataṁ teṣāṁ vivekādr̥te</l>
                 <l n="b">kaś cid dhanty aparaś ca rakṣati sr̥jaty anyaś ca kr̥tsnaṁ jagat·<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">devo <supplied reason="omitted">’</supplied>yaṁ tu guṇaiḥ kr̥to vahutithair ddhīmān· jaghāma dviṣo</l>
                 <l n="d">vr̥tta-sthāna-puṣac cakāra ca<lb n="18"/> ripūcchedena divyāḥ prajāḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
             </lg>
             <lg n="19" met="śārdūlavikrīḍita">
                 <l n="a">dattvā divya-bhuvaḥ prati-kṣiti-bhr̥tām urvvīm urīkurvvatā</l>
                 <l n="b">vīrāsr̥g-lipi-lāñchito ’sir amunā prāg eva pattrī-kr̥taḥ<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">netthaṁ cet· katham anyathā vasumatī bhoge vivādonmukhī</l>
                 <l n="d">tatrākr̥ṣṭa-kr̥pāṇa-dhāriṇi gatā bha<g ref="sym:barCross" type="connector">§</g><lb n="19" break="no"/>ṅgaṁ dviṣāṁ santatiḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g>||[21]</l>
              <lg n="20" met="vasantatilakā">
                  <l n="a">tvaṁ nānya-vīra-vijayīti giraḥ kavīnāṁ</l>
                  <l n="b">śrutvā ’nyathā-manana-rūḍha-nigūḍha-roṣaḥ<g ref="sym:bar" type="punctuation">.</g></l>
                  <l n="c">gauḍendram adravad apākr̥ta kāmarūpa</l>
                  <l n="d">-bhūpaṁ kaliṅgam api yas tarasā jigāya<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
             </lg>
             <lg n="21" met="śārdūlavikrīḍita">
                 <l n="a">śūram manya Ivāsi nānya kim iha svaṁ rāghava ślāghase</l>
                 <l n="b">spa<g ref="barCross" type="connector">§</g><lb n="20" break="no"/>rddhāṁ varddhana muñca vīra virato nādyāpi darppas tava<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">Ity anyonyam ahar-nniśa-praṇayibhiḥ kolāhalaiḥ kṣmā-bhujāṁ</l>
                 <l n="d">yat·-kārā-gr̥ha-yāmikair nniyamito nidrāpanoda-klamaḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
             </lg>
             <lg n="22" met="vasantatilakā">
                 <l n="a">pāścatya-cakra-jaya-keliṣu yasya yāvad</l>
                 <l n="b">gaṅgā-pravāham anudhāvati<g ref="sym:barCross" type="connector">§</g><lb n="21"/> nau-vitāne<g ref="sym:bar" type="punctuation">.</g></l>
                 <l n="c">bharggasya mauli-sarid-ambhasi bhasma-paṅka</l>
                 <l n="d">-lagnojjhiteva tarir indu-kalā cakāsti<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
            </lg>
            <lg n="23" met="sragdharā">
                <l n="a">muktāḥ karppāsa-vījair mmarakata-śakalaṁ śāka-pattrair alāvū</l>
                <l n="b">-puṣpai rūpyāṇi ratnaṁ pariṇati-bhidurair kukṣibhir ddāḍimānām·<g ref="sym:bar" type="punctuation">.</g></l>
                <l n="c">kuṣmaṇḍī-vallarīṇāṁ vi<lb n="22" break="no"/>kasita-kusumaiḥ kāñcanaṁ nāgarībhiḥ</l>
                <l n="d">śikṣyante yat·-prasādād vahu-vibhava-juṣāṁ yoṣitaḥ śrotriyāṇām·<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
            </lg>
            <lg n="24" met="indravajrā">
                <l n="a">Aśrānta-viśrāṇita-yajña-yūpa</l>
                <l n="b">-stambhāvalīṁ drāg avalamvamānaḥ<g ref="sym:bar" type="punctuation">.</g></l>
                <l n="c">yasyānubhāvād bhuvi sañcacāra</l>
                <l n="d">kāla-kramād eka-pado <supplied reason="omitted">’</supplied>pi dharmmaḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
            </lg>
            <lg n="25" met="śārdūlavikrīḍita">
                <l n="a">meror ā<lb n="23" break="no"/>hata-vairi-saṅkula-taṭād āhūya yajvāmarān·</l>
                <l n="b">vyatyāsaṁ pura-vāsinām akr̥ta yaḥ svarggasya marttyasya ca<g ref="sym:bar" type="punctuation">.</g></l>
                <l n="c">Uttuṅgaiḥ sura-sadmabhiś ca vitatais tallaiś ca śeṣī-kr̥taṁ</l>
                <l n="d">cakre yena parasparasya ca samaṁ dyāvā-pr̥thivyor vvapuḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
            </lg>
            <lg n="26" met="sragdharā">
                <l n="a">dik-śākhā-mūla-kāṇḍaṁ gagana-tala-ma<g ref="sym:barCross" type="connector">§</g><lb n="24" break="no"/>hāmbho-dhi-madhyāntarīyaṁ</l>
                <l n="b">bhānoḥ prāk-pratyag-adri-sthiti-milad-udayāstasya madhyāhna-śailam·<g ref="sym:bar" type="punctuation">.</g></l>
                <l n="c">Ālamva-stambham ekaṁ tri-bhuvana-bhavanasyaika-śeṣaṁ girīṇāṁ</l>
                <l n="d">sa pradyumneśvarasya vyadhita vasumatī-vāsavaḥ saudham uccaiḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
            </lg>
            <lg n="27" met="śārdūlavikrīḍita">
                <l n="a">prāsādena tavāmunaiva haritām adhvā<g ref="sym:barCross" type="connector">§</g><lb n="25"/> niruddho mudhā</l>
                <l n="b">bhāno <supplied reason="omitted">’</supplied>dyāpi kr̥to <supplied reason="omitted">’</supplied>sti dakṣiṇa-diśaḥ koṇānta-vāsī muniḥ<g ref="sym:bar" type="punctuation">.</g></l>
                <l n="c">Anyām uccha-patho <supplied reason="omitted">’</supplied>yam r̥cchatu diśaṁ vindhyo <supplied reason="omitted">’</supplied>py asau varddhatāṁ</l>
                <l n="d">yāvac-chakti tathāpi nāsya padavīṁ saudhasya gāhiṣyate<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
            </lg>
            <lg n="28" met="upajāti">
                <l n="a" met="indravajrā">sraṣṭā yadi srakṣyati bhūmi-cakre</l>
                <l n="b" met="upendravajrā">sumeru-mr̥t<unclear>·</unclear>-piṇḍa-viva<lb n="26" break="no"/>rttanābhiḥ<g ref="sym:bar" type="punctuation">.</g></l>
                <l n="c" met="upendravajrā">tadā ghaṭaḥ syād upamānam asmin·</l>
                <l n="d" met="upendravajrā">suvarṇṇa-kumbhasya tad-arppitasya<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
            </lg>
            <lg n="29" met="pr̥thvī">
                <l n="a">vileśaya-vilāsinī-mukuṭa-koṭi-ratnāṅkura</l>
                <l n="b">sphurat·-kiraṇa-mañjarī-cchurita-vāri-pūraṁ puraḥ<g ref="sym:bar" type="punctuation">.</g></l>
                <l n="c">cakhāna pura-vairiṇaḥ sa jala-magna<g ref="sym:barCross" type="connector">§</g><lb n="27" break="no"/>-paurāṅganā</l>
                <l n="d">-stanaiṇa-mada-saurabhoccalita-cañcarīkaṁ saraḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
            </lg>
            <lg n="30" met="śārdūlavikrīḍita">
                <l n="a">Uccitrāṇi dig-amvarasya vasanāny arddhāṅganā-svāmino</l>
                <l n="b">ratnālaṁkr̥tibhir vviśeṣita-vapuḥ śobhāḥ śataṁ subhruvaḥ<space unit="character" quantity="1" type="vacat"/><g ref="sym:bar" type="punctuation">.</g></l>
                <l n="c">paurāḍhyāś ca purīḥ śmaśāna-vasater bhikṣā-bhu<lb n="28" break="no"/>jo <supplied reason="omitted">’</supplied>syākṣayāṁ</l>
                <l n="d">lakṣmīṁ sa vyatanoddaridra-bharaṇe sujño hi senānvayaḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
            </lg>
            <lg n="31" met="sragdharā">
                <l n="a">citra-kṣaumebha-carmmā hr̥daya-vinihita-sthūla-hāroragendraḥ</l>
                <l n="b">śrī-khaṇḍa-kṣoda-bhasmā kara-milita-mahā-nīla-ratnākṣa-mālaḥ<g ref="sym:bar" type="punctuation">.</g></l>
                <l n="c">veṣas tenāsya tene garuḍa-maṇi-latā-gona<g ref="sym:bar" type="connector">§</g><lb n="29" break="no"/>saḥ kānta-muktā</l>
                <l n="d">-nepathya-nrasthir icchā-samucita-racanaḥ kalpa-kapālikasya<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
            </lg>
            <lg n="32" met="śārdūlavikrīḍita">
                <l n="a">vāhoḥ kelibhir advitīya-kanaka-cchattraṁ dharitrī-talaṁ</l>
                <l n="b">kurvvāṇena na paryaśeṣi kim api svenaiva tenehitam·<g ref="sym:bar" type="punctuation">.</g></l>
                <l n="c">kin tasmai diśatu prasanna-varado <supplied reason="omitted">’</supplied>py arddhendu-mauliḥ<lb n="30"/> paraṁ</l>
                <l n="d">svaṁ sāyujyam asāv apaścima-daśā-śeṣe punar-ddāsyati<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
            </lg>
            <lg n="33" met="vasantatilakā">
                <l n="a">prastotum asya<del rend="strikeout">ṁ</del> paritaś caritaṁ kṣmaḥ syāt·</l>
                <l n="b">prācetaso yadi parāśara-nandano vā<g ref="sym:bar" type="punctuation">.</g></l>
                <l n="c">tat·-kīrtti-pūra-sura-sindhu-vigāhanena</l>
                <l n="d">vācaḥ pavitrayitum atra tu naḥ prayatnaḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
            </lg>
            <lg n="34" met="mandākrāntā">
                <l n="a">yāvad vāstos-pati<lb n="31" break="no"/>-pura-dhunī bhūr bhuvaḥ svaḥ punīte</l>
                <l n="b">yāvac cāndrī kalayati kalottaṁsatāṁ bhūta-bharttuḥ<g ref="sym:bar" type="punctuation">.</g></l>
                <l n="c">yāvac ceto gamayati satāṁ śvetimānaṁ tri-vedī</l>
                <l n="d">tāvat tāsāṁ racayatu sakhī tat tad evāsya kīrttiḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
            </lg>
            <lg n="35" met="vasantatilakā">
                <l n="a">nirṇṇikta-sena-kula-bhū-pati-mauktikānām</l>
                <l n="b">agranthila-gra<lb n="32" break="no"/>thana-pakṣmala-sūtra-valliḥ<g ref="sym:bar" type="punctuation">.</g></l>
                <l n="c">Eṣā kaveḥ pada-padārtha-vicāra-śuddha</l>
                <l n="d">-buddher umāpatidharasya kr̥tiḥ praśastiḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
            </lg>
            <lg n="36" met="upajāti">
                <l n="a" met="indravajrā">dharmm<choice><sic>o</sic><corr>a</corr></choice>-pranaptā manadāsa-naptā</l>
                <l n="b" met="updravajrā">vr̥haspateḥ sūnur imāṁ praśastiṁ<supplied reason="omitted"><g ref="sym:bar" type="punctuation">.</g></supplied></l>
                <l n="c" met="indravajrā">cakhāna vārendraka-śilpi-goṣṭhī</l>
                <l n="d" met="indravajrā">-cūḍā-maṇī rāṇaka-śūlapāṇiḥ<g ref="sym:doubleBar-serifed" type="punctuation">.</g><space unit="character" quantity="2" type="vacat"/><g ref="sym:doubleBar-serifed" type="punctuation">.</g></l>
            </lg>
         </div>
